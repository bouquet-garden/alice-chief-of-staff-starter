{
  "display_information": {
    "name": "Alice",
    "description": "Founder OS Assistant",
    "background_color": "#1c1954"
  },
  "features": {
    "app_home": { "home_tab_enabled": true, "messages_tab_enabled": true, "messages_tab_read_only_enabled": false },
    "bot_user": { "display_name": "Alice", "always_online": false },
    "slash_commands": [
      { "command": "/alice-brief", "description": "Generate a concise operating brief", "should_escape": false },
      { "command": "/alice-reconcile", "description": "Find cross-system contradictions", "should_escape": false },
      { "command": "/alice-followups", "description": "Show stale threads and next moves", "should_escape": false }
    ]
  },
  "oauth_config": {
    "scopes": {
      "bot": [
        "app_mentions:read",
        "chat:write",
        "chat:write.customize",
        "commands",
        "channels:history",
        "channels:read",
        "groups:read",
        "im:history",
        "im:read",
        "im:write",
        "mpim:history",
        "mpim:read",
        "mpim:write",
        "reactions:read",
        "reactions:write",
        "pins:read",
        "pins:write",
        "users:read",
        "users:read.email",
        "files:read",
        "search:read.public",
        "search:read.im",
        "search:read.mpim"
      ]
    }
  },
  "settings": {
    "event_subscriptions": {
      "bot_events": [
        "app_mention",
        "message.channels",
        "message.im",
        "reaction_added",
        "pin_added"
      ]
    },
    "interactivity": { "is_enabled": true },
    "socket_mode_enabled": true,
    "token_rotation_enabled": false,
    "org_deploy_enabled": false
  }
}
